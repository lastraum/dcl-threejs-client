[Unit]
Description=DCL login analytics (JSONL append)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/dcl-analytics
Environment=ANALYTICS_PORT=8787
Environment=ANALYTICS_LOG_PATH=/var/lib/dcl-analytics/logins.jsonl
ExecStart=/usr/bin/node /opt/dcl-analytics/analytics.mjs
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target